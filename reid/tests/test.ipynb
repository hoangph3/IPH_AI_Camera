   "source": [
    "import chromadb\n",
    "from chromadb.config import Settings\n",
    "\n",
    "chroma_client = chromadb.HttpClient(host=\"https://google.com\", port=8000,settings=Settings(allow_reset=True, anonymized_telemetry=False))\n",
    "print(chroma_client.heartbeat())\n"
   ]
