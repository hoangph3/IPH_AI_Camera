{
    "backend": {
        "mongo": {
            "tracking": {
                "uri": "mongodb://admin:password@mct-mongodb:27017/admin",
                "database": "iph",
                "collection": "tracking"
            },
            "reid": {
                "uri": "mongodb://admin:password@mct-mongodb:27017/admin",
                "database": "iph",
                "collection": "reid"
            },
            "report": {
                "uri": "mongodb://admin:password@mct-mongodb:27017/admin",
                "database": "iph",
                "collection": "report",
                "batch_time": 3600
            }
        },
        "chroma": {
            "host": "mct-chroma",
            "port": 8000,
            "collection": "reid"
        }
    },
    "clustering": {
        "threshold": 0.6,
        "linkage": "average",
        "n_neighbors": 5
    },
    "matching": {
        "threshold": 0.6,
        "top_k": 20
    },
    "rerank": {
        "k1": 20,
        "k2": 6,
        "lambda_value": 0.3,
        "threshold": 0.6
    },
    "metric": "euclidean",
    "interval": 5,
    "batch_time": 600,
    "batch_size": 1000
}